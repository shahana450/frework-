# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJYOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=eyJYOUR_SERVICE_ROLE_KEY_HERE   # Settings → API → service_role

# ── Razorpay ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXX          # public — used in browser checkout
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXX                      # server-side order creation
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET                # Razorpay → Settings → Webhooks

# ── Meta / Facebook Pixel ─────────────────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=1234567890123456                 # Meta Business → Events Manager

# ── FreWork contact ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPPORT_PHONE=+919999999999                    # shown on /lp & success screen
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999                   # without +, for wa.me links

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://frework.online
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=                      # Google Search Console

# ── Optional: Twilio (WhatsApp lead alerts to admin) ─────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# ADMIN_WHATSAPP=whatsapp:+91XXXXXXXXXX
